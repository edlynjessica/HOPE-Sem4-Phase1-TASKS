// 1295. Find Numbers with Even Number of Digits

Number Crunching
class Solution {
    public int findNumbers(int[] nums) {
        int c=0;
        for(int i:nums){
            int n=0;
            while(i>0){
                n++;
                i/=10;
            }
            if(n%2==0) c++;
        }
        return c;
    }
}

