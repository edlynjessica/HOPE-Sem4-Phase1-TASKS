// 34. Find First and Last Position of Element in Sorted Array

class Solution {
    public int[] searchRange(int[] nums, int target) {
        int left=0;
        int right=nums.length-1;
        int n=nums.length;
        int[] arr={-1,-1};
        while(left<=right){
            int mid=left+(right-left)/2;
            if(nums[mid]==target){
                int l=mid;
                // go left and check if its the first occurence
                while(l>=0 && nums[l]==target){
                    l--;
                }
                arr[0]=l+1;
                // go right to find the last occurence
                int r=mid;
                while(r<n && nums[r]==target) r++;
                arr[1]=r-1;
                break;
            }else if(nums[mid]>target){
                right=mid-1;
            }else {
                left=mid+1;
            }
        }
        return arr;
    }
}

