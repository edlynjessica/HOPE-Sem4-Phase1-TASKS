// 283. Move Zeroes

class Solution {
    public void moveZeroes(int[] nums) {
        int ptr=-1;
        int n=nums.length;
        int j=0;
        for(int i=0;i<n;i++){
            if(nums[i]!=0){
                nums[j]=nums[i];
                j++;
            }
        }
        for(int i=j;i<n;i++){
            nums[i]=0;
        }
    }
}

