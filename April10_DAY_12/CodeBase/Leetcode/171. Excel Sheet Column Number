// 171. Excel Sheet Column Number

class Solution {
    public int titleToNumber(String columnTitle) {
        int pow=0;
        int n=columnTitle.length();
        int res=0;
        for(int i=n-1;i>=0;i--){
            res+=(columnTitle.charAt(i)-'A'+1)*Math.pow(26,pow);
            pow++;
        }
        return res;
    }
}

